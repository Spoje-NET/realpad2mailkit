#!/usr/bin/make -f
# You must remove unused comment lines for the released package.
#export DH_VERBOSE = 1
#export DEB_BUILD_MAINT_OPTIONS = hardening=+all
#export DEB_CFLAGS_MAINT_APPEND  = -Wall -pedantic
#export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed

PKG_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/~.*//')
PKG_SOURCE  := $(shell dpkg-parsechangelog -S Source)

%:
	dh $@ --with phpcomposer

override_dh_install:
	dh_install
	sed -i "1a defined('APP_NAME') || define('APP_NAME', '$(PKG_SOURCE)');" \
		debian/realpad2mailkit/usr/share/realpad2mailkit/autoload.php
	sed -i "2a defined('APP_VERSION') || define('APP_VERSION', '$(PKG_VERSION)');" \
		debian/realpad2mailkit/usr/share/realpad2mailkit/autoload.php
	sed -i -e 's/..\/i18n/\/usr\/share\/locale/g'            	        		debian/realpad2mailkit/usr/share/realpad2mailkit/*.php
	sed -i -e "s/require_once __DIR__\.'\/\.\.\/vendor\/autoload\.php'/require_once __DIR__.'\/autoload.php'/" debian/realpad2mailkit/usr/share/realpad2mailkit/*.php
	sed -i -e "s/..\/.env//" debian/realpad2mailkit/usr/share/realpad2mailkit/*.php
	jq '.version = "'`dpkg-parsechangelog | sed -n 's/^Version: //p'| sed 's/~.*//'`'"'  multiflexi/realpad_to_mailkit.multiflexi.app.json |sponge debian/multiflexi-realpad2mailkit/usr/lib/realpad2mailkit/multiflexi/realpad_to_mailkit.multiflexi.app.json
